{
  "description": "Loop plugin hooks - repeating prompt loop control via Stop hook",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/loop-stop-hook.py",
            "timeout": 7200,
            "statusMessage": "Checking loop..."
          }
        ]
      }
    ]
  }
}
